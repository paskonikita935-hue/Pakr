<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#99000000">

    <!-- 底部半屏卡片 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@drawable/disclaimer_bg"
        android:maxHeight="620dp">

        <!-- 拖动指示条 -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"
            android:background="#E0E0E0"
            android:backgroundTint="#CCCCCC"/>

        <!-- 标题区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="使用须知"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#0D0D0D"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="请阅读以下条款后勾选同意"
                android:textSize="13sp"
                android:textColor="#999999"
                android:layout_marginTop="3dp"/>
        </LinearLayout>

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0F0F0"/>

        <!-- 可滚动正文 -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="never"
            android:fadeScrollbars="false">

            <TextView
                android:id="@+id/tvDisclaimerBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#444444"
                android:lineSpacingMultiplier="1.7"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"/>
        </ScrollView>

        <!-- 分隔线 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0F0F0"/>

        <!-- Checkbox -->
        <CheckBox
            android:id="@+id/cbAgree"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="我已阅读并同意以上全部条款"
            android:textSize="14sp"
            android:textColor="#333333"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:buttonTint="#0D0D0D"/>

        <!-- 按钮区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="32dp"
            android:paddingTop="4dp">

            <Button
                android:id="@+id/btnDecline"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="不同意"
                android:textSize="15sp"
                android:textColor="#555555"
                android:backgroundTint="#F0F0F0"
                android:layout_marginEnd="12dp"
                android:stateListAnimator="@null"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>

            <Button
                android:id="@+id/btnAccept"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="2"
                android:text="同意并继续"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#0D0D0D"
                android:stateListAnimator="@null"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
